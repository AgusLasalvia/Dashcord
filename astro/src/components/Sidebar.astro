---
const { active = "music" } = Astro.props;
---

<aside class="sidebar">
	<div class="sidebar-title">
		<i class="bi bi-disc-fill sidebar-logo"></i>
	</div>
	<nav class="sidebar-nav">
		<a href="#" class={`sidebar-link${active === "music" ? " active" : ""}`}
			><i class="bi bi-music-note-beamed"></i> <span>Música</span></a
		>
		<a href="#" class={`sidebar-link${active === "profile" ? " active" : ""}`}
			><i class="bi bi-person"></i> <span>Perfil</span></a
		>
		<a href="#" class={`sidebar-link${active === "search" ? " active" : ""}`}
			><i class="bi bi-search"></i> <span>Buscar Canción</span></a
		>
		<a href="#" class={`sidebar-link${active === "settings" ? " active" : ""}`}
			><i class="bi bi-gear"></i> <span>Ajustes</span></a
		>
	</nav>
</aside>
<style>
	.sidebar {
		background: #2c2f33;
		width: 60px;
		transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1);
		display: flex;
		flex-direction: column;
		padding: 1rem 0.2rem;
		box-shadow: 2px 0 16px rgba(0, 0, 0, 0.1);
		overflow: hidden;
		z-index: 2;
	}
	.sidebar:hover {
		width: 220px;
		padding: 2rem 1rem 1rem 1rem;
	}
	.sidebar-title {
		font-size: 1.1rem;
		font-weight: 700;
		color: #5865f2;
		margin-bottom: 1.2rem;
		letter-spacing: 1px;
		text-align: center;
		opacity: 0;
		transition: opacity 0.18s;
		white-space: nowrap;
	}
	.sidebar:hover .sidebar-title {
		font-size: 1.7rem;
		margin-bottom: 2.5rem;
		opacity: 1;
	}
	.sidebar-nav {
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
	}
	.sidebar-link {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		color: #b9bbbe;
		text-decoration: none;
		font-size: 1.1rem;
		font-weight: 500;
		padding: 0.7rem 1rem;
		border-radius: 8px;
		transition:
			background 0.18s,
			color 0.18s;
		white-space: nowrap;
	}
	.sidebar-link.active,
	.sidebar-link:hover {
		background: #23272a;
		color: #fff;
	}
	.sidebar-link i {
		font-size: 1.3rem;
		min-width: 24px;
		text-align: center;
	}
	.sidebar-link span {
		display: none;
		opacity: 0;
		transition:
			opacity 0.18s,
			display 0s linear 0.18s;
	}
	.sidebar:hover .sidebar-link span {
		display: inline;
		opacity: 1;
		transition: opacity 0.18s;
		margin-left: 0.2rem;
	}
	@media (max-width: 900px) {
		.sidebar {
			width: 60px;
			padding: 1rem 0.2rem;
		}
		.sidebar-title {
			font-size: 1.1rem;
			margin-bottom: 1.2rem;
		}
		.sidebar-link span {
			display: none !important;
		}
		.sidebar-link i {
			margin-right: 0;
		}
	}
	.sidebar-logo {
		font-size: 2.5rem;
		color: #5865f2;
		display: block;
		margin: 0 auto;
		transition: color 0.2s;
	}
	.sidebar:hover .sidebar-logo {
		color: #fff;
	}
</style>
