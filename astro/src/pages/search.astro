---
import SongCard from "../components/SongCard.astro";
import DashboardLayout from "../layouts/DashboardLayout.astro";
import { songs } from "../lib/song";
---

<DashboardLayout active="search">
	<header class="dashboard-header">
		<span>Buscar Canción</span>
	</header>
	<section class="music-list-section">
		<form class="search-form" method="get" action="/search">
			<input
				id="search"
				type="text"
				name="q"
				class="search-bar"
				placeholder="Buscar canción o artista..."
				required
			/>
			<button type="submit" class="search-btn"
				><i class="bi bi-search"></i> Buscar</button
			>
		</form>
		<div class="music-grid" id="grid">
			<!-- {
				songs.map((song: any) => (
					<SongCard title={song.title} youtube_id={song.youtube_id} />
				))
			} -->
		</div>
	</section>

	<script type="module">
		import SongCard from "../components/SongCard.astro";
		document.querySelector("#grid").innerHTML
	</script>
</DashboardLayout>

<style>
	.dashboard-header {
		font-size: 1.1rem;
		color: #b9bbbe;
		margin-bottom: 2rem;
		text-align: right;
	}
	.search-form {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1rem;
		margin-bottom: 2.5rem;
		flex-wrap: wrap;
	}
	.search-bar {
		width: 100%;
		max-width: 400px;
		padding: 0.7rem 1.1rem;
		border-radius: 8px;
		border: 1.5px solid #23272a;
		background: #23272a;
		color: #fff;
		font-size: 1.05rem;
		font-family: inherit;
		transition:
			border 0.2s,
			box-shadow 0.2s;
		box-shadow: 0 2px 8px rgba(88, 101, 242, 0.05);
		text-align: center;
	}
	.search-bar:focus {
		border-color: #5865f2;
		outline: none;
		box-shadow: 0 0 0 2px #5865f2aa;
	}
	.search-btn {
		background: linear-gradient(90deg, #5865f2 0%, #4752c4 100%);
		color: #fff;
		border: none;
		border-radius: 8px;
		font-size: 1.1rem;
		font-weight: 600;
		padding: 0.7rem 1.5rem;
		cursor: pointer;
		transition: background 0.2s;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		box-shadow: 0 2px 8px rgba(88, 101, 242, 0.1);
	}
	.search-btn:hover {
		background: linear-gradient(90deg, #4752c4 0%, #5865f2 100%);
	}
	.music-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1.5rem;
		padding: 0;
		margin: 0;
	}
	@media (max-width: 1200px) {
		.music-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
	@media (max-width: 900px) {
		.dashboard-header {
			padding: 0 0.5rem;
		}
		.music-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 600px) {
		.music-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
